openapi: 3.0.3
info:
  title: Django Lokdown
  version: 1.1.2
  contact:
    name: Loknus Labs LLC
    email: loknuslabs@gmail.com
    url: https://loknuslabs.io
  license:
    name: GNU General Public License v3.0
    url: https://www.gnu.org/licenses/gpl-3.0.html
paths:
  /api/auth/token:
    post:
      operationId: auth_token_create
      description: |-
        Takes a set of user credentials and returns an access and refresh JSON web
        token pair to prove the authentication of those credentials.
      summary: Obtain JWT token pair
      tags:
      - Authentication
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CustomTokenObtainPairRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/CustomTokenObtainPairRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/CustomTokenObtainPairRequest'
        required: true
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SimpleJwtTokenPairResponse'
          description: ''
        '401':
          description: Invalid credentials or 2FA required
  /api/auth/token/refresh:
    post:
      operationId: auth_token_refresh_create
      description: Takes a valid refresh token and returns a new access token.
      summary: Refresh JWT token
      tags:
      - Authentication
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
        required: true
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TokenRefresh'
          description: ''
  /api/auth/token/verify:
    post:
      operationId: auth_token_verify_create
      description: |-
        Takes a set of user credentials and returns an access and refresh JSON web
        token pair to prove the authentication of those credentials.
      summary: Complete token generation after 2FA
      tags:
      - Authentication
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TokenVerify2FARequestRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TokenVerify2FARequestRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TokenVerify2FARequestRequest'
        required: true
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SimpleJwtTokenPairResponse'
          description: ''
        '401':
          description: Invalid 2FA token
        '400':
          description: Invalid session
  /api/auth/login:
    post:
      operationId: auth_login_create
      summary: Initialize login with 2FA
      tags:
      - Authentication
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/LoginInitRequestRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/LoginInitRequestRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/LoginInitRequestRequest'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Pre2FALoginResponse'
          description: ''
        '401':
          description: Invalid credentials
        '429':
          description: Too many authentication attempts
  /api/auth/verify:
    post:
      operationId: auth_verify_create
      summary: Verify 2FA and complete login
      tags:
      - Authentication
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/LoginVerifyRequestRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/LoginVerifyRequestRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/LoginVerifyRequestRequest'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TokenPairResponse'
          description: ''
        '401':
          description: Invalid 2FA token
        '400':
          description: Invalid session or missing token
        '429':
          description: Too many authentication attempts
  /api/auth/oauth/providers:
    get:
      operationId: auth_oauth_providers_retrieve
      description: 'Returns headless redirect metadata for each provider configured
        via Django admin Social applications (or `SOCIALACCOUNT_PROVIDERS`). Prefer
        `GET /_allauth/browser/v1/config` for dynamic provider discovery; this endpoint
        pre-fills `callback_url` for lokdown''s JWT bridge. `callback_url` must pass
        allauth `is_safe_url` and, when set, `LOKDOWN_SOCIALAUTH_ALLOWED_CALLBACK_ORIGINS`.
        SPA flow: POST a form to `redirect_url` with `provider`, `callback_url`, `process=login`,
        and `csrfmiddlewaretoken`, then call `POST /api/auth/oauth/callback` with
        session cookie and CSRF header.'
      summary: List configured OAuth providers
      parameters:
      - in: query
        name: callback_url
        schema:
          type: string
        description: Post-OAuth redirect URL for allauth headless. Use your SPA callback
          route (absolute URL). Defaults to project `auth_callback` when omitted.
      - in: query
        name: next
        schema:
          type: string
        description: Alias for `callback_url` (legacy query param).
      tags:
      - OAuth
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/OAuthProvidersResponse'
          description: ''
        '400':
          description: Invalid or disallowed callback_url
        '503':
          description: allauth not installed or no providers configured
  /api/auth/oauth/{provider}/login:
    get:
      operationId: auth_oauth_login_retrieve
      description: Returns headless redirect metadata to start browser OAuth for Google/GitHub/etc.
        POST a form to `redirect_url` with `provider`, `callback_url`, `process=login`,
        and `csrfmiddlewaretoken` (synchronous form submit, not XHR). `callback_url`
        must pass allauth `is_safe_url` and, when set, `LOKDOWN_SOCIALAUTH_ALLOWED_CALLBACK_ORIGINS`.
        After OAuth completes, call `POST /api/auth/oauth/callback` from your SPA
        with session cookie and `X-CSRFToken` to receive JWTs or a pre-2FA `session_id`.
      summary: OAuth redirect metadata for one provider
      parameters:
      - in: query
        name: callback_url
        schema:
          type: string
        description: Post-OAuth redirect URL passed to allauth headless. Prefer your
          SPA callback (absolute URL). Defaults to project `auth_callback` when omitted.
      - in: query
        name: next
        schema:
          type: string
        description: Alias for `callback_url` (legacy query param).
      - in: path
        name: provider
        schema:
          type: string
        description: Provider id (google, github, …)
        required: true
      tags:
      - OAuth
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/OAuthProviderRedirect'
          description: ''
        '400':
          description: Invalid or disallowed callback_url
        '404':
          description: Unknown provider
        '503':
          description: allauth not installed or provider not configured
  /api/auth/oauth/callback:
    post:
      operationId: auth_oauth_callback_create
      description: 'Primary SPA callback endpoint. Call after OAuth when the browser
        has a Django session cookie (`sessionid` on the API origin). Returns JSON
        only — same shape as `POST /api/auth/login` when 2FA is off, or `session_id`
        + flags for `POST /api/auth/verify` when 2FA is enabled. Authenticates via
        Django **session cookie** (`sessionid`), not Bearer JWT. Requires **POST**
        with CSRF protection (`X-CSRFToken` header or `csrfmiddlewaretoken` body field).
        Same-origin SPAs can proxy `/accounts/*` and `/api/*` through Vite (e.g. `http://localhost:5173`)
        so the cookie is set on one host. Cross-origin SPAs need `fetch(..., { credentials:
        ''include'' })` plus `CSRF_TRUSTED_ORIGINS` / `CORS_ALLOW_CREDENTIALS`.'
      summary: Complete OAuth login (session to JWT)
      tags:
      - OAuth
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/OAuthSessionBridgeResponse'
          description: ''
        '401':
          description: Not authenticated (no OAuth session cookie)
        '403':
          description: CSRF verification failed
        '503':
          description: allauth not installed
        '500':
          description: Failed to create lokdown login session
  /api/auth/2fa/setup/totp:
    post:
      operationId: auth_2fa_setup_totp_create
      summary: Setup TOTP for authenticated user
      tags:
      - 2FA TOTP
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TOTPSetupResponse'
          description: ''
  /api/auth/2fa/verify/totp:
    post:
      operationId: auth_2fa_verify_totp_create
      summary: Verify TOTP setup
      tags:
      - 2FA TOTP
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TOTPVerifySetupRequestRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TOTPVerifySetupRequestRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TOTPVerifySetupRequestRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TwoFactorSetupCompleteResponse'
          description: ''
        '401':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: ''
  /api/auth/2fa/passkey/credentials:
    get:
      operationId: auth_2fa_passkey_credentials_list
      summary: List passkey credentials
      tags:
      - 2FA Passkey
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/PasskeyCredential'
          description: ''
  /api/auth/2fa/passkey/remove:
    delete:
      operationId: auth_2fa_passkey_remove_destroy
      summary: Remove passkey credential
      parameters:
      - in: query
        name: credential_id
        schema:
          type: string
        required: true
      tags:
      - 2FA Passkey
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/MessageResponse'
          description: ''
  /api/auth/2fa/passkey/setup:
    post:
      operationId: auth_2fa_passkey_setup_create
      summary: Setup passkey for authenticated user
      tags:
      - 2FA Passkey
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PasskeySetupResponse'
          description: ''
  /api/auth/2fa/passkey/verify:
    post:
      operationId: auth_2fa_passkey_verify_create
      summary: Verify passkey setup
      tags:
      - 2FA Passkey
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PasskeyVerifySetupRequestRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PasskeyVerifySetupRequestRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PasskeyVerifySetupRequestRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TwoFactorSetupCompleteResponse'
          description: ''
        '401':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: ''
  /api/auth/2fa/passkey/options:
    post:
      operationId: auth_2fa_passkey_options_create
      summary: Get passkey authentication options for login
      tags:
      - 2FA Passkey
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PasskeyAuthOptionsRequestRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PasskeyAuthOptionsRequestRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PasskeyAuthOptionsRequestRequest'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PasskeyAuthOptionsResponse'
          description: ''
  /api/auth/2fa/verify/backup:
    post:
      operationId: auth_2fa_verify_backup_create
      summary: Verify backup code and complete login
      tags:
      - 2FA Backup Code
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/BackupCodeVerifyRequestRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/BackupCodeVerifyRequestRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/BackupCodeVerifyRequestRequest'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BackupCodeVerifyResponse'
          description: ''
        '401':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: ''
        '429':
          description: Too many attempts
  /api/auth/2fa/status:
    get:
      operationId: auth_2fa_status_retrieve
      summary: Get 2FA status
      tags:
      - 2FA
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TwoFactorStatusResponse'
          description: ''
  /api/auth/2fa/disable:
    post:
      operationId: auth_2fa_disable_create
      summary: Disable 2FA
      tags:
      - 2FA
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DisableTwoFAResponse'
          description: ''
  /api/auth/admin/2fa/passkey/options:
    post:
      operationId: auth_admin_2fa_passkey_options_create
      description: Generate passkey challenge for admin 2FA verify page (uses Django
        session cookie).
      summary: Admin passkey authentication options
      tags:
      - 2FA Passkey
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AdminPasskeyAuthOptionsResponse'
          description: ''
        '400':
          description: No active session
  /api/auth/api-keys:
    post:
      operationId: auth_api_keys_create
      summary: Create an API key
      tags:
      - API Keys
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ApiKeyCreateRequestRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ApiKeyCreateRequestRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ApiKeyCreateRequestRequest'
      security:
      - jwtAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ApiKeyCreatedResponse'
          description: ''
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: ''
        '403':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: ''
    get:
      operationId: auth_api_keys_retrieve
      summary: List API keys for the authenticated user
      tags:
      - API Keys
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ApiKeyListResponse'
          description: ''
        '403':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: ''
  /api/auth/api-keys/{key_id}:
    delete:
      operationId: auth_api_keys_destroy
      summary: Revoke an API key
      parameters:
      - in: path
        name: key_id
        schema:
          type: integer
        required: true
      tags:
      - API Keys
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ApiKeyRevokeResponse'
          description: ''
        '403':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: ''
components:
  schemas:
    AdminPasskeyAuthOptionsResponse:
      type: object
      properties:
        challenge:
          type: string
        rp_id:
          type: string
        timeout:
          type: integer
        allow_credentials: {}
      required:
      - challenge
      - rp_id
      - timeout
    ApiKeyCreateRequestRequest:
      type: object
      properties:
        name:
          type: string
          maxLength: 255
        expires_in_days:
          type: integer
          minimum: 1
          description: Days until expiry. Omit for indefinite when allowed by settings.
    ApiKeyCreatedResponse:
      type: object
      properties:
        id:
          type: integer
        name:
          type: string
        prefix:
          type: string
          description: Visible key prefix for identification
        api_key:
          type: string
          description: Full key — shown once at creation
        created_at:
          type: string
          format: date-time
        expires_at:
          type: string
          format: date-time
          nullable: true
      required:
      - api_key
      - created_at
      - expires_at
      - id
      - name
      - prefix
    ApiKeyListResponse:
      type: object
      properties:
        api_keys:
          type: array
          items:
            $ref: '#/components/schemas/ApiKeyMetadata'
      required:
      - api_keys
    ApiKeyMetadata:
      type: object
      properties:
        id:
          type: integer
        name:
          type: string
        prefix:
          type: string
        created_at:
          type: string
          format: date-time
        last_used_at:
          type: string
          format: date-time
          nullable: true
        expires_at:
          type: string
          format: date-time
          nullable: true
        is_active:
          type: boolean
      required:
      - created_at
      - expires_at
      - id
      - is_active
      - last_used_at
      - name
      - prefix
    ApiKeyRevokeResponse:
      type: object
      properties:
        message:
          type: string
      required:
      - message
    BackupCodeVerifyRequestRequest:
      type: object
      properties:
        session_id:
          type: string
          minLength: 1
        backup_code:
          type: string
          minLength: 1
      required:
      - backup_code
      - session_id
    BackupCodeVerifyResponse:
      type: object
      properties:
        access_token:
          type: string
        refresh_token:
          type: string
        requires_2fa:
          type: boolean
        message:
          type: string
      required:
      - access_token
      - message
      - refresh_token
      - requires_2fa
    CustomTokenObtainPairRequest:
      type: object
      properties:
        username:
          type: string
          writeOnly: true
          minLength: 1
        password:
          type: string
          writeOnly: true
          minLength: 1
      required:
      - password
      - username
    DisableTwoFAResponse:
      type: object
      properties:
        message:
          type: string
      required:
      - message
    ErrorResponse:
      type: object
      properties:
        error:
          type: string
      required:
      - error
    LoginInitRequestRequest:
      type: object
      properties:
        username:
          type: string
          minLength: 1
        password:
          type: string
          writeOnly: true
          minLength: 1
      required:
      - password
      - username
    LoginVerifyRequestRequest:
      type: object
      properties:
        session_id:
          type: string
          minLength: 1
        totp_token:
          type: string
        passkey_response: {}
        backup_code:
          type: string
      required:
      - session_id
    MessageResponse:
      type: object
      properties:
        message:
          type: string
      required:
      - message
    OAuthProviderRedirect:
      type: object
      description: |-
        Headless OAuth start metadata for one provider.

        Use :meth:`for_provider` to build a validated instance from the current request.
      properties:
        provider:
          type: string
          description: Provider id (e.g. google, github)
        redirect_url:
          type: string
          format: uri
          description: POST target for allauth headless browser provider redirect
        callback_url:
          type: string
          format: uri
          description: SPA route allauth redirects to after OAuth completes. Must
            pass allauth `is_safe_url` and, when set, ``LOKDOWN_SOCIALAUTH_ALLOWED_CALLBACK_ORIGINS``.
        redirect_method:
          type: string
          description: HTTP method for redirect_url (always "POST" for headless browser
            flow)
      required:
      - callback_url
      - provider
      - redirect_method
      - redirect_url
    OAuthProvidersResponse:
      type: object
      properties:
        providers:
          type: array
          items:
            $ref: '#/components/schemas/OAuthProviderRedirect'
      required:
      - providers
    OAuthSessionBridgeResponse:
      type: object
      description: JWT pair or pre-2FA session after OAuth (same shape as password
        login).
      properties:
        requires_2fa:
          type: boolean
        access_token:
          type: string
        refresh_token:
          type: string
        session_id:
          type: string
        totp_enabled:
          type: boolean
        passkey_enabled:
          type: boolean
        backup_codes_available:
          type: boolean
      required:
      - requires_2fa
    PasskeyAuthOptionsRequestRequest:
      type: object
      properties:
        session_id:
          type: string
          minLength: 1
      required:
      - session_id
    PasskeyAuthOptionsResponse:
      type: object
      properties:
        challenge:
          type: string
        rp_id:
          type: string
        timeout:
          type: integer
        options: {}
      required:
      - challenge
      - options
      - rp_id
      - timeout
    PasskeyCredential:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        credential_id:
          type: string
          maxLength: 255
        sign_count:
          type: integer
          maximum: 9223372036854775807
          minimum: -9223372036854775808
          format: int64
        rp_id:
          type: string
          maxLength: 255
        user_handle:
          type: string
          maxLength: 255
        created_at:
          type: string
          format: date-time
          readOnly: true
        last_used:
          type: string
          format: date-time
          nullable: true
      required:
      - created_at
      - credential_id
      - id
      - rp_id
      - user_handle
    PasskeySetupResponse:
      type: object
      properties:
        session_id:
          type: string
        options: {}
      required:
      - options
      - session_id
    PasskeyVerifySetupRequestRequest:
      type: object
      properties:
        session_id:
          type: string
          minLength: 1
        passkey_response: {}
      required:
      - passkey_response
      - session_id
    Pre2FALoginResponse:
      type: object
      properties:
        session_id:
          type: string
        requires_2fa:
          type: boolean
        totp_enabled:
          type: boolean
        passkey_enabled:
          type: boolean
        backup_codes_available:
          type: boolean
      required:
      - backup_codes_available
      - passkey_enabled
      - requires_2fa
      - session_id
      - totp_enabled
    SimpleJwtTokenPairResponse:
      type: object
      properties:
        access:
          type: string
        refresh:
          type: string
        requires_2fa:
          type: boolean
      required:
      - access
      - refresh
      - requires_2fa
    TOTPSetupResponse:
      type: object
      properties:
        secret:
          type: string
        qr_code:
          type: string
        provisioning_uri:
          type: string
      required:
      - provisioning_uri
      - qr_code
      - secret
    TOTPVerifySetupRequestRequest:
      type: object
      properties:
        totp_token:
          type: string
          minLength: 1
      required:
      - totp_token
    TokenPairResponse:
      type: object
      properties:
        access_token:
          type: string
        refresh_token:
          type: string
        requires_2fa:
          type: boolean
      required:
      - access_token
      - refresh_token
      - requires_2fa
    TokenRefresh:
      type: object
      properties:
        access:
          type: string
          readOnly: true
        refresh:
          type: string
      required:
      - access
      - refresh
    TokenRefreshRequest:
      type: object
      properties:
        refresh:
          type: string
          minLength: 1
      required:
      - refresh
    TokenVerify2FARequestRequest:
      type: object
      properties:
        session_id:
          type: string
          minLength: 1
        totp_token:
          type: string
        passkey_response: {}
        backup_code:
          type: string
      required:
      - session_id
    TwoFactorSetupCompleteResponse:
      type: object
      description: Returned after successful TOTP or passkey enrollment verification.
      properties:
        message:
          type: string
        backup_codes:
          type: array
          items:
            type: string
          description: Plaintext backup codes shown once after setup. Empty when passkey
            enrollment did not generate new codes (user already had codes).
      required:
      - backup_codes
      - message
    TwoFactorStatusResponse:
      type: object
      properties:
        is_enabled:
          type: boolean
          readOnly: true
        totp_enabled:
          type: boolean
          readOnly: true
        passkey_enabled:
          type: boolean
          readOnly: true
      required:
      - is_enabled
      - passkey_enabled
      - totp_enabled
  securitySchemes:
    cookieAuth:
      type: apiKey
      in: cookie
      name: sessionid
    jwtAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
