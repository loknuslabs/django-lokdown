                            "schema": {
                                "$ref": "#/components/schemas/LoginInitRequestRequest"
                            }
                        },
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginInitRequestRequest"
                            }
                        }
                    },
                    "required": true
                },
                "security": [
                    {
                        "jwtAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Pre2FALoginResponse"
                                }
                            }
                        },
                        "description": ""
                    },
                    "401": {
                        "description": "Invalid credentials"
                    }
                }
            }
        },
        "/api/auth/verify": {
            "post": {
                "operationId": "auth_verify_create",
                "summary": "Verify 2FA and complete login",
                "tags": [
                    "Authentication"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginVerifyRequestRequest"
                            }
                        },
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginVerifyRequestRequest"
                            }
                        },
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginVerifyRequestRequest"
                            }
                        }
                    },
                    "required": true
                },
                "security": [
                    {
                        "jwtAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/TokenPairResponse"
                                }
                            }
                        },
                        "description": ""
                    },
                    "401": {
                        "description": "Invalid 2FA token"
                    },
                    "400": {
                        "description": "Invalid session or missing token"
                    },
                    "429": {
                        "description": "Too many backup code attempts"
                    }
                }
            }
        },
