    "components": {
        "schemas": {
            "AdminPasskeyAuthOptionsResponse": {
                "type": "object",
                "properties": {
                    "challenge": {
                        "type": "string"
                    },
                    "rp_id": {
                        "type": "string"
                    },
                    "timeout": {
                        "type": "integer"
                    },
                    "allow_credentials": {}
                },
                "required": [
                    "challenge",
                    "rp_id",
                    "timeout"
                ]
            },
            "BackupCodeVerifyRequestRequest": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string",
                        "minLength": 1
                    },
                    "backup_code": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "required": [
                    "backup_code",
                    "session_id"
                ]
            },
            "BackupCodeVerifyResponse": {
                "type": "object",
                "properties": {
                    "access_token": {
                        "type": "string"
                    },
                    "refresh_token": {
                        "type": "string"
                    },
                    "requires_2fa": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    }
                },
                "required": [
                    "access_token",
                    "message",
                    "refresh_token",
                    "requires_2fa"
                ]
            },
            "CustomTokenObtainPairRequest": {
                "type": "object",
                "properties": {
                    "username": {
                        "type": "string",
                        "writeOnly": true,
                        "minLength": 1
                    },
                    "password": {
                        "type": "string",
                        "writeOnly": true,
                        "minLength": 1
                    }
                },
                "required": [
                    "password",
                    "username"
                ]
            },
            "DisableTwoFAResponse": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string"
                    }
                },
                "required": [
                    "message"
                ]
            },
            "ErrorResponse": {
                "type": "object",
                "properties": {
                    "error": {
                        "type": "string"
                    }
                },
                "required": [
                    "error"
                ]
            },
            "LoginInitRequestRequest": {
                "type": "object",
                "properties": {
                    "username": {
                        "type": "string",
                        "minLength": 1
                    },
                    "password": {
                        "type": "string",
                        "writeOnly": true,
                        "minLength": 1
                    }
                },
                "required": [
                    "password",
                    "username"
                ]
            },
            "LoginVerifyRequestRequest": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string",
                        "minLength": 1
                    },
                    "totp_token": {
                        "type": "string"
                    },
                    "passkey_response": {},
                    "backup_code": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id"
                ]
            },
            "MessageResponse": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string"
                    }
                },
                "required": [
                    "message"
                ]
            },
            "PasskeyAuthOptionsRequestRequest": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "required": [
                    "session_id"
                ]
            },
            "PasskeyAuthOptionsResponse": {
                "type": "object",
                "properties": {
                    "challenge": {
                        "type": "string"
                    },
                    "rp_id": {
                        "type": "string"
                    },
                    "timeout": {
                        "type": "integer"
                    },
                    "options": {}
                },
                "required": [
                    "challenge",
                    "options",
                    "rp_id",
                    "timeout"
                ]
            },
            "PasskeyCredential": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "credential_id": {
                        "type": "string",
                        "maxLength": 255
                    },
                    "sign_count": {
                        "type": "integer",
                        "maximum": 9223372036854775807,
                        "minimum": -9223372036854775808,
                        "format": "int64"
                    },
                    "rp_id": {
                        "type": "string",
                        "maxLength": 255
                    },
                    "user_handle": {
                        "type": "string",
                        "maxLength": 255
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "readOnly": true
                    },
                    "last_used": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    }
                },
                "required": [
                    "created_at",
                    "credential_id",
                    "id",
                    "rp_id",
                    "user_handle"
                ]
            },
            "PasskeySetupResponse": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "options": {}
                },
                "required": [
                    "options",
                    "session_id"
                ]
            },
            "PasskeyVerifySetupRequestRequest": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string",
                        "minLength": 1
                    },
                    "passkey_response": {}
                },
                "required": [
                    "passkey_response",
                    "session_id"
                ]
            },
            "Pre2FALoginResponse": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "requires_2fa": {
                        "type": "boolean"
                    },
                    "totp_enabled": {
                        "type": "boolean"
                    },
                    "passkey_enabled": {
                        "type": "boolean"
                    },
                    "backup_codes_available": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "backup_codes_available",
                    "passkey_enabled",
                    "requires_2fa",
                    "session_id",
                    "totp_enabled"
                ]
            },
            "SimpleJwtTokenPairResponse": {
                "type": "object",
                "properties": {
                    "access": {
                        "type": "string"
                    },
                    "refresh": {
                        "type": "string"
                    },
                    "requires_2fa": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "access",
                    "refresh",
                    "requires_2fa"
                ]
            },
            "TOTPSetupResponse": {
                "type": "object",
                "properties": {
                    "secret": {
                        "type": "string"
                    },
                    "qr_code": {
                        "type": "string"
                    },
                    "provisioning_uri": {
                        "type": "string"
                    }
                },
                "required": [
                    "provisioning_uri",
                    "qr_code",
                    "secret"
                ]
            },
            "TOTPVerifySetupRequestRequest": {
                "type": "object",
                "properties": {
                    "totp_token": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "required": [
                    "totp_token"
                ]
            },
            "TokenPairResponse": {
                "type": "object",
                "properties": {
                    "access_token": {
                        "type": "string"
                    },
                    "refresh_token": {
                        "type": "string"
                    },
                    "requires_2fa": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "access_token",
                    "refresh_token",
                    "requires_2fa"
                ]
            },
            "TokenRefresh": {
                "type": "object",
                "properties": {
                    "access": {
                        "type": "string",
                        "readOnly": true
                    },
                    "refresh": {
                        "type": "string"
                    }
                },
                "required": [
                    "access",
                    "refresh"
                ]
            },
            "TokenRefreshRequest": {
                "type": "object",
                "properties": {
                    "refresh": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "required": [
                    "refresh"
                ]
            },
            "TokenVerify2FARequestRequest": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string",
                        "minLength": 1
                    },
                    "totp_token": {
                        "type": "string"
                    },
                    "passkey_response": {},
                    "backup_code": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id"
                ]
            },
            "TwoFactorSetupCompleteResponse": {
                "type": "object",
                "description": "Returned after successful TOTP or passkey enrollment verification.",
                "properties": {
                    "message": {
                        "type": "string"
                    },
                    "backup_codes": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Plaintext backup codes shown once after setup. Empty when passkey enrollment did not generate new codes (user already had codes)."
                    }
                },
                "required": [
                    "backup_codes",
                    "message"
                ]
            },
            "TwoFactorStatusResponse": {
                "type": "object",
                "properties": {
                    "is_enabled": {
                        "type": "boolean",
                        "readOnly": true
                    },
                    "totp_enabled": {
                        "type": "boolean",
                        "readOnly": true
                    },
                    "passkey_enabled": {
                        "type": "boolean",
                        "readOnly": true
                    }
                },
                "required": [
                    "is_enabled",
                    "passkey_enabled",
                    "totp_enabled"
                ]
            }
        },
        "securitySchemes": {
            "jwtAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        }
    }
}